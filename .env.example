# Supabase — copy to .env and fill in your project values
# Dashboard → Project Settings → API (use JWT anon + service_role keys)

VITE_SUPABASE_URL=https://rzeptkazqjiflnzcrnwr.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt-key

# Set to "true" to use Supabase instead of local Express server
VITE_USE_SUPABASE=true

# Scripts only (confirm-user.mjs) — never expose in frontend / Vercel
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-key